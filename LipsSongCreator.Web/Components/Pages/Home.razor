@page "/"
@page "/editor"
@using LipsSongCreator.Web.Services
@inject SongService Song
@inject DlcBuildService DlcBuilder
@inject MediaCacheService MediaCache
@inject NavigationManager Nav
@inject IJSRuntime JS
@rendermode InteractiveServer

@if (!Song.IsLoaded)
{
    <!-- ── Landing Screen ──────────────────────────────────────── -->
    <div class="toolbar">
        <span class="toolbar-brand">Lips Song Creator</span>
    </div>

    <div class="upload-screen">
        <div class="drop-zone" style="cursor:pointer;" @onclick='() => Nav.NavigateTo("/create")'>
            <div class="dz-icon">&#128230;</div>
            <div class="dz-title">Neues DLC erstellen</div>
            <div class="dz-sub">
                UltraStar-Song in ein fertiges Xbox-DLC umwandeln.
                Schritt-fuer-Schritt-Assistent mit YouTube-Import.
            </div>
        </div>

        <div class="drop-zone">
            <div class="dz-icon">&#127925;</div>
            <div class="dz-title">Song editieren</div>
            <div class="dz-sub">.X360 (Lips) oder .txt (UltraStar) im Piano-Roll-Editor oeffnen</div>
            <InputFile OnChange="OnFileSelected" accept=".X360,.x360,.txt,.TXT" />
        </div>

        @if (_loading)
        {
            <div style="display:flex; align-items:center; gap:0.5rem;">
                <div class="spinner"></div>
                <span style="color:var(--text-secondary)">Lade Song...</span>
            </div>
        }
        @if (_error != null)
        {
            <div style="color:var(--accent-secondary);max-width:480px;text-align:center;">@_error</div>
        }
    </div>
}
else
{
    <!-- ── Toolbar ─────────────────────────────────────────────── -->
    <div class="toolbar">
        <span class="toolbar-brand">Lips Song Creator</span>
        <div class="toolbar-sep"></div>

        <button class="btn-t" @onclick="CloseSong">Datei schliessen</button>
        @if (Song.IsUltraStarMode)
        {
            <button class="btn-accent" @onclick="ExportStfs" disabled="@DlcBuilder.IsRunning">
                @(DlcBuilder.IsRunning ? (DlcBuilder.CurrentStep ?? "Baue DLC...") : "Export DLC")
            </button>
            <button class="btn-t" @onclick="ExportSong">Export ZIP</button>
        }
        else
        {
            <button class="btn-accent" @onclick="ExportSong">Export .X360</button>
        }

        <div class="toolbar-sep"></div>

        <button class="btn-t btn-play" title="Abspielen (ab Playhead)" @onclick="PlayAudio">&#9654;</button>
        <button class="btn-t btn-play" title="Pause" @onclick="PauseAudio">&#10074;&#10074;</button>
        <button class="btn-t btn-play" title="Stop" @onclick="StopAudio">&#9632;</button>
        @if (!_audioLoaded && Song.IsUltraStarMode)
        {
            <span style="font-size:0.7rem;color:var(--text-muted);">(kein Audio geladen)</span>
        }

        <div class="toolbar-sep"></div>

        <button class="btn-t @(_previewVisible ? "active" : "")" title="Preview-Bereich anzeigen/setzen" @onclick="TogglePreview">Preview</button>

        <div class="toolbar-sep"></div>

        <button class="btn-t" @onclick="ZoomIn" title="Zoom +">+</button>
        <button class="btn-t" @onclick="ZoomOut" title="Zoom -">&minus;</button>

        <div class="toolbar-meta">
            @if (_meta != null)
            {
                <span><strong>@_meta.Artist</strong> - <strong>@_meta.Name</strong></span>
            }
        </div>
    </div>

    <!-- ── Editor Area ─────────────────────────────────────────── -->
    <div class="editor-area">

        <!-- Piano Strip -->
        <div class="piano-strip">
            <div class="piano-keys" style="top: @(-_pianoScrollY)px;">
                @for (var n = MAX_NOTE; n >= MIN_NOTE; n--)
                {
                    var note = n;
                    var name = NOTE_NAMES[note % 12];
                    var isBlack = BLACKS.Contains(note % 12);
                    var isC = note % 12 == 0;
                    var oct = note / 12 - 1;
                    <div class="p-key @(isBlack ? "b" : "w") @(isC ? "c" : "")"
                         style="height:16px;">
                        @if (isC || name == "E" || name == "A")
                        {
                            @($"{name}{oct}")
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Canvas -->
        <div class="canvas-wrap">
            <canvas id="pianoCanvas"></canvas>
        </div>

        <!-- Sequence Panel -->
        <div class="seq-panel">
            @if (_meta != null)
            {
                <h6>Metadaten</h6>
                <div class="meta-form">
                    <label>Titel</label>
                    <input type="text" @bind="_meta.Name" />
                    <label>Artist</label>
                    <input type="text" @bind="_meta.Artist" />
                    <label>Album</label>
                    <input type="text" @bind="_meta.Album" />
                    <label>Genre</label>
                    <input type="text" @bind="_meta.Genre" />
                    <label>Jahr</label>
                    <input type="text" @bind="_meta.Year" />
                    <label>Sprache</label>
                    <input type="text" @bind="_meta.Language" />
                </div>
            }

            <h6>Sequenzen</h6>
            @foreach (var seq in _sequences)
            {
                var s = seq;
                var isActive = s.Name == _activeSeq;
                <div class="seq-item @(isActive ? "active" : "")" @onclick="() => SelectSequence(s.Name)">
                    <span>@s.Name</span>
                    <span class="cnt">@s.MarkerCount</span>
                </div>
            }

            @if (_selectedNote >= 0 && _selectedNote < _activeMarkers.Count)
            {
                var m = _activeMarkers[_selectedNote];
                <h6>Selektierte Note</h6>
                <div style="font-size:0.75rem;color:var(--text-secondary);padding:0.25rem;">
                    <div><span style="color:var(--text-muted)">Typ:</span> @ShortName(m.ClassName)</div>
                    <div><span style="color:var(--text-muted)">Zeit:</span> <span style="color:var(--accent-primary);font-family:monospace">@m.TimingFormatted</span></div>
                    <div><span style="color:var(--text-muted)">Laenge:</span> @m.Length.ToString("F3")s</div>
                    @if (m.NoteName != null)
                    {
                        <div><span style="color:var(--text-muted)">Note:</span> <strong style="color:var(--accent-gold)">@m.NoteName</strong></div>
                    }
                    @if (Song.IsUltraStarMode && _activeSeq == "Melody")
                    {
                        <label style="color:var(--text-muted);display:block;margin-top:0.4rem;">Silbe</label>
                        <input type="text" value="@m.FreeWord" @onchange="UpdateSelectedSyllable"
                               style="width:100%;margin-top:0.15rem;" />
                        <div style="color:var(--text-muted);font-size:0.62rem;margin-top:0.25rem;line-height:1.4;">
                            Leerzeichen am Ende = Wortende.<br />
                            Note ziehen = verschieben, Kanten = Laenge.
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(m.FreeWord))
                    {
                        <div><span style="color:var(--text-muted)">Silbe:</span> "@m.FreeWord"</div>
                    }
                    @if (!string.IsNullOrEmpty(m.TagName))
                    {
                        <div><span style="color:var(--text-muted)">Tag:</span> @m.TagName</div>
                    }
                </div>
            }
        </div>

        <!-- Timeline -->
        <div class="timeline-bar"></div>

        <!-- Lyrics Bar -->
        <div class="lyrics-bar">
            @if (_lyricMarkers.Count > 0)
            {
                @for (var i = 0; i < _lyricMarkers.Count; i++)
                {
                    var lm = _lyricMarkers[i];
                    var word = lm.FreeWord ?? "";
                    if (string.IsNullOrEmpty(word)) continue;
                    var isOn = i == _activeLyricIdx;
                    <span class="syl @(isOn ? "on" : "") @(lm.EndOfWord ? "we" : "")">@word</span>
                }
            }
            else
            {
                <span style="color:var(--text-muted);font-size:0.8rem;">Lyrics werden hier angezeigt...</span>
            }
        </div>
    </div>

    <!-- Properties Bar -->
    <div class="props-bar">
        <span><span class="lbl">Sequenz:</span> <span class="val">@_activeSeq</span></span>
        <span><span class="lbl">Marker:</span> <span class="val">@_activeMarkers.Count</span></span>
        <span><span class="lbl">Zoom:</span> <span class="val">@_zoom px/s</span></span>
        @if (_meta != null)
        {
            <span><span class="lbl">Offset:</span> <span class="val">@_meta.BaseCentOffset ct</span></span>
        }
    </div>
}

@code {
    private const int MIN_NOTE = 36;
    private const int MAX_NOTE = 84;
    private static readonly string[] NOTE_NAMES = {"C","C#","D","D#","E","F","F#","G","G#","A","A#","B"};
    private static readonly HashSet<int> BLACKS = new() {1,3,6,8,10};

    private bool _loading;
    private string? _error;
    private bool _audioLoaded;
    private bool _previewVisible;
    private SongMetadata? _meta;
    private List<SequenceInfo> _sequences = [];
    private List<MarkerInfo> _activeMarkers = [];
    private List<MarkerInfo> _lyricMarkers = [];
    private string _activeSeq = "Melody";
    private int _selectedNote = -1;
    private int _activeLyricIdx = -1;
    private int _zoom = 80;
    private int _pianoScrollY = 200; // Start etwas runter gescrollt
    private DotNetObjectReference<Home>? _dotNetRef;
    private bool _canvasInitialized;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _loading = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            var isUltraStar = file.Name.EndsWith(".txt", StringComparison.OrdinalIgnoreCase);

            if (isUltraStar)
            {
                // UltraStar TXT laden
                using var reader = new StreamReader(file.OpenReadStream(50 * 1024 * 1024));
                var content = await reader.ReadToEndAsync();
                Song.LoadUltraStar(file.Name, content);
            }
            else
            {
                // Lips .X360 laden
                using var ms = new MemoryStream();
                await file.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
                Song.Load(file.Name, ms.ToArray());
            }

            _meta = Song.GetMetadata();
            _sequences = Song.GetSequences();

            // Lade Lyrics
            var lyricSeq = _sequences.FirstOrDefault(s => s.Name == "Lyric");
            _lyricMarkers = lyricSeq?.Markers ?? [];

            // Lade aktive Sequenz (Melody)
            SelectSequenceData("Melody");
        }
        catch (Exception ex)
        {
            _error = $"Fehler: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Song.IsLoaded && !_canvasInitialized)
        {
            _canvasInitialized = true;
            _dotNetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("pianoRoll.init", "pianoCanvas", _dotNetRef);
            await PushNotesToCanvas();
            await LoadAudioFromStagedProject();
            await SyncPreviewToCanvas();
        }
    }

    /// <summary>
    /// Laedt die Audio-Datei aus dem Wizard-Projekt in den Media-Cache
    /// und verbindet sie mit dem Piano-Roll-Player (Vorschau/Abtiming).
    /// </summary>
    private async Task LoadAudioFromStagedProject()
    {
        if (DlcBuilder.PendingFiles == null) return;

        var audioKey = DlcBuilder.PendingFiles.Keys.FirstOrDefault(k =>
            Path.GetExtension(k).ToLowerInvariant()
                is ".mp3" or ".m4a" or ".ogg" or ".flac" or ".wav" or ".mp4" or ".webm");
        if (audioKey == null) return;

        var cacheKey = MediaCache.Store(DlcBuilder.PendingFiles[audioKey], audioKey);
        await JS.InvokeVoidAsync("pianoRoll.loadAudio", $"/media/{cacheKey}");
        _audioLoaded = true;
    }

    private async Task SyncPreviewToCanvas()
    {
        var start = Song.GetPreviewStart();
        if (start > 0)
        {
            _previewVisible = true;
            await JS.InvokeVoidAsync("pianoRoll.setPreview", start, 15);
        }
    }

    // ── Audio-Steuerung ──────────────────────────────────────

    private async Task PlayAudio()
    {
        var ok = await JS.InvokeAsync<bool>("pianoRoll.playAudio", (object?)null);
        if (!ok) _error = "Kein Audio geladen. Audio kommt aus dem Wizard-Projekt (Schritt 2).";
    }

    private async Task PauseAudio() => await JS.InvokeVoidAsync("pianoRoll.pauseAudio");
    private async Task StopAudio() => await JS.InvokeVoidAsync("pianoRoll.stopAudio");

    // ── Preview-Bereich ──────────────────────────────────────

    private async Task TogglePreview()
    {
        _previewVisible = !_previewVisible;
        if (_previewVisible)
        {
            var start = Song.GetPreviewStart();
            if (start <= 0)
            {
                // Default: 30% der Songdauer (wie die Pipeline)
                var seqDur = _activeMarkers.Count > 0
                    ? _activeMarkers.Max(m => m.TriggerTiming + m.Length)
                    : 60;
                start = seqDur * 0.3;
                Song.SetPreviewStart(start);
            }
            await JS.InvokeVoidAsync("pianoRoll.setPreview", start, 15);
        }
        else
        {
            await JS.InvokeVoidAsync("pianoRoll.setPreview", -1, 15);
        }
    }

    [JSInvokable]
    public void OnPreviewChanged(double start, double length)
    {
        Song.SetPreviewStart(start);
        InvokeAsync(StateHasChanged);
    }

    // ── Note-Editing (Callback aus dem Canvas) ───────────────

    [JSInvokable]
    public void OnNoteEdited(int idx, double time, double length, int midiPitch, string syllable)
    {
        // midiPitch (0-basiert ab C-1*12) -> UltraStar-Pitch (relativ zu C4=60)
        if (_activeSeq is "Melody" && Song.IsUltraStarMode)
        {
            Song.UpdateNote(idx, time, length, midiPitch - 60, syllable);
            _sequences = Song.GetSequences();
            var lyricSeq = _sequences.FirstOrDefault(s => s.Name == "Lyric");
            _lyricMarkers = lyricSeq?.Markers ?? [];
            SelectSequenceData(_activeSeq);
            InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateSelectedSyllable(ChangeEventArgs e)
    {
        if (_selectedNote < 0 || _selectedNote >= _activeMarkers.Count) return;
        if (!Song.IsUltraStarMode || _activeSeq != "Melody") return;

        var m = _activeMarkers[_selectedNote];
        Song.UpdateNote(_selectedNote, m.TriggerTiming, m.Length,
            (int)((m.ToneOctave ?? 4) * 12 + (m.ToneFIdx ?? 0) + 12 - 60),
            e.Value?.ToString() ?? "");
        _sequences = Song.GetSequences();
        var lyricSeq = _sequences.FirstOrDefault(s => s.Name == "Lyric");
        _lyricMarkers = lyricSeq?.Markers ?? [];
        SelectSequenceData(_activeSeq);
        _ = PushNotesToCanvas();
    }

    private async Task PushNotesToCanvas()
    {
        // Konvertiere Marker zu JS-kompatiblem Format
        var jsNotes = _activeMarkers
            .Where(m => m.ToneFIdx != null || !string.IsNullOrEmpty(m.FreeWord) || !string.IsNullOrEmpty(m.TagName))
            .Select(m => new {
                time = m.TriggerTiming,
                length = Math.Max(m.Length, 0.05f),
                fIdx = m.ToneFIdx ?? 0,
                octave = m.ToneOctave ?? 4,
                syllable = m.FreeWord ?? m.TagName ?? "",
                type = "normal"
            }).ToList();

        await JS.InvokeVoidAsync("pianoRoll.setNotes", jsNotes);
    }

    [JSInvokable]
    public void OnNoteSelected(int idx)
    {
        _selectedNote = idx;
        InvokeAsync(StateHasChanged);
    }

    private void SelectSequence(string name)
    {
        SelectSequenceData(name);
        _ = PushNotesToCanvas();
    }

    private void SelectSequenceData(string name)
    {
        _activeSeq = name;
        _selectedNote = -1;
        var seq = _sequences.FirstOrDefault(s => s.Name == name);
        _activeMarkers = seq?.Markers ?? [];
    }

    private async Task ZoomIn()
    {
        _zoom = Math.Min(400, _zoom + 20);
        await JS.InvokeVoidAsync("pianoRoll.setZoom", _zoom);
    }

    private async Task ZoomOut()
    {
        _zoom = Math.Max(20, _zoom - 20);
        await JS.InvokeVoidAsync("pianoRoll.setZoom", _zoom);
    }

    protected override void OnInitialized()
    {
        DlcBuilder.ProgressChanged += () => InvokeAsync(StateHasChanged);

        // Song wurde ggf. schon vom Wizard geladen (Navigation zu /editor):
        // Metadaten und Sequenzen aus dem Service uebernehmen
        if (Song.IsLoaded && _meta == null)
        {
            _meta = Song.GetMetadata();
            _sequences = Song.GetSequences();
            var lyricSeq = _sequences.FirstOrDefault(s => s.Name == "Lyric");
            _lyricMarkers = lyricSeq?.Markers ?? [];
            SelectSequenceData("Melody");
        }
    }

    private void CloseSong()
    {
        _meta = null;
        _sequences = [];
        _activeMarkers = [];
        _lyricMarkers = [];
        _canvasInitialized = false;
        DlcBuilder.ClearPendingProject();
        Song.Unload();
        _ = JS.InvokeVoidAsync("pianoRoll.destroy");
        Nav.NavigateTo("/");
    }

    private async Task ExportStfs()
    {
        try
        {
            if (!Song.IsLoaded || !Song.IsUltraStarMode) return;

            byte[] bytes;
            string fileName;

            if (DlcBuilder.HasPendingProject)
            {
                // Editor-Aenderungen (Noten, Silben, Preview) in die .txt
                // zurueckschreiben, damit die Pipeline sie verwendet
                var editedTxt = Song.SerializeUltraStar();
                if (editedTxt != null)
                {
                    var txtKey = DlcBuilder.PendingFiles!.Keys.First(k =>
                        k.EndsWith(".txt", StringComparison.OrdinalIgnoreCase));
                    DlcBuilder.PendingFiles[txtKey] = System.Text.Encoding.UTF8.GetBytes(editedTxt);
                }

                // Wizard-Projekt: Komplett-Pipeline mit Audio/Video/Cover
                var result = await DlcBuilder.BuildPendingAsync();
                bytes = DlcBuilder.ReadAndCleanup(result);
                fileName = result.StfsFileName;
            }
            else
            {
                // Nur-Chart-Export (ohne Medien) - z.B. wenn eine .txt direkt
                // im Editor geoeffnet wurde
                bytes = Song.ExportAsStfs();
                // Dateiname MUSS ContentID + "4D" sein - Lips/XContent validiert
                // dass der Dateiname dem Header-Hash entspricht
                fileName = LipsSongExtractor.StfsWriter.GetRequiredFileName(bytes);
            }

            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("fileDownload.save", fileName, base64);
        }
        catch (Exception ex)
        {
            _error = $"STFS-Export fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task ExportSong()
    {
        try
        {
            if (!Song.IsLoaded) return;

            byte[] bytes;
            string fileName;

            if (Song.IsUltraStarMode)
            {
                // ZIP mit allen generierten Dateien + Anleitung
                bytes = Song.ExportAsZip();
                var title = _meta?.Name ?? "Song";
                fileName = $"{title}_LipsDLC.zip";
            }
            else
            {
                // Einzelne modifizierte .X360
                bytes = Song.Export();
                fileName = Song.FileName?.Replace(".X360", "_modified.X360") ?? "export.X360";
            }

            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("fileDownload.save", fileName, base64);
        }
        catch (Exception ex)
        {
            _error = $"Export fehlgeschlagen: {ex.Message}";
        }
    }

    private static string ShortName(string n) =>
        n.Replace("lps", "").Replace("ixSeq", "").Replace("ix", "");

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
